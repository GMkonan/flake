SERVER_IP=192.168.1.20

DASH_HOST=dash.lan
PORTAINER_HOST=portainer.lan
KYOO_HOST=kyoo.lan
QBIT_HOST=qbit.lan
SONARR_HOST=sonarr.lan
RADARR_HOST=radarr.lan
BAZARR_HOST=bazarr.lan
PROWLARR_HOST=prowlarr.lan
GLANCES_HOST=glances.lan

