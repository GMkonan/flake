TZ=America/Sao_Paulo
PUID=501
PGID=20

APPDATA_ROOT=/Users/konan/srv/appdata
MEDIA_ROOT=/Volumes/MEDIA/media
BACKUP_ROOT=/Volumes/MEDIA/backups/appdata
