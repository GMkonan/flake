RADARR_PORT=7878
BAZARR_PORT=6767
PROWLARR_PORT=9696
HOMEPAGE_PORT=3000
PORTAINER_PORT=9000
GLANCES_PORT=61208

KYOO_PUBLIC_URL=http://kyoo.lan
LIBRARY_LANGUAGES=en
LIBRARY_IGNORE_PATTERN=.*/[dD]ownloads?/.*
